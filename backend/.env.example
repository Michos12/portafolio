# Copy this file to backend/.env and fill in the values.
# NEVER commit .env (it is already in .gitignore).

# --- Supabase ---
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_KEY=your-secret-or-anon-key

# --- Auth / JWT ---
# Generate a long random secret: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-with-a-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
ADMIN_USERNAME=admin
# bcrypt hash of the password (NOT the plaintext). Generate it with:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'YOUR_PASSWORD', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=

# --- GitHub API ---
# Just the username, e.g. "Michos12" (NOT the full profile URL).
GITHUB_USERNAME=your-github-username
# Optional token (classic, no scopes): raises the limit from 60 to 5000 req/h
GITHUB_TOKEN=
GITHUB_CACHE_TTL=600

# --- CORS ---
# In production: your Vercel domain. Multiple values comma-separated.
FRONTEND_ORIGIN=http://localhost:4200
